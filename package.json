{
    "name": "cg2r",
    "description": "CG²R (Conseil Général – Generalrat) — A visual data exploration application for analyzing election results of the city of Fribourg from 1996 to 2026.",
    "version": "1.0.0",
    "type": "module",
    "license": "CC-BY-NC-4.0",
    "author": "Nicolas Feyer",
    "repository": {
        "type": "git",
        "url": "https://github.com/nicolasfeyer/cg2r"
    },
    "homepage": "https://elections.nicolasfeyer.ch",
    "keywords": [
        "elections",
        "fribourg",
        "data-visualization",
        "react",
        "typescript",
        "conseil-general",
        "open-data",
        "swiss-politics"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
